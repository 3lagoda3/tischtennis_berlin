# Copy this file to ".env.local" and fill in the two values from your Supabase project.
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-OR-PUBLISHABLE-KEY

# ---- Optional: light edit protection ----
# Leave both unset and editing stays open to anyone with the link (default).
# Set BOTH to require a shared password before adding/editing/deleting.
#   NEXT_PUBLIC_EDIT_PROTECTED  -> tells the UI to show the lock (public, safe)
#   EDIT_PASSWORD               -> the actual password (server-only, never exposed)
# NEXT_PUBLIC_EDIT_PROTECTED=true
# EDIT_PASSWORD=choose-a-shared-password
