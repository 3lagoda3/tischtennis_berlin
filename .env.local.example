# Copy this file to ".env.local" and fill in the two values from your Supabase project.
# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-OR-PUBLISHABLE-KEY

# ---- Admin password ----
# All editing (players, games, tournaments, gallery) is gated behind this.
# Defaults to "pinqponq" if unset; set your own to actually secure it.
# ADMIN_PASSWORD=choose-your-admin-password
